---
---

<!-- Search Toggle Button -->
<button
  type="button"
  id="search-toggle"
  aria-label="搜索 (⌘K)"
  title="搜索 (⌘K)"
  class="flex items-center justify-center rounded-md p-1 text-foreground/60 hover:text-foreground transition-colors"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="8"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
</button>

<!-- Search Overlay -->
<div
  id="search-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="站内搜索"
  class="fixed inset-0 z-50 hidden"
>
  <!-- Backdrop -->
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-background/80 backdrop-blur-sm"
    aria-hidden="true"
  ></div>

  <!-- Dialog -->
  <div class="relative flex justify-center px-4 pt-[20vh]">
    <div
      class="w-full max-w-xl overflow-hidden rounded-lg border border-border bg-background shadow-xl"
    >
      <!-- Input Row -->
      <div class="flex items-center gap-2 border-b border-border px-3">
        <svg
          class="shrink-0 text-muted-foreground"
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="搜索文章..."
          autocomplete="off"
          spellcheck="false"
          aria-autocomplete="list"
          aria-controls="search-results"
          class="min-w-0 flex-1 bg-transparent py-3 text-sm text-foreground outline-none placeholder:text-muted-foreground [&::-webkit-search-cancel-button]:hidden"
        />
        <kbd
          class="hidden shrink-0 rounded border border-border px-1.5 py-0.5 text-[10px] text-muted-foreground sm:block"
          >ESC</kbd
        >
      </div>

      <!-- Results Area -->
      <div id="search-results-area" class="max-h-80 overflow-y-auto">
        <!-- Empty state -->
        <div
          id="search-empty"
          class="flex flex-col items-center justify-center gap-2 py-10 text-sm text-muted-foreground"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span>输入关键词开始搜索</span>
        </div>

        <!-- No results state -->
        <div
          id="search-no-results"
          class="hidden py-10 text-center text-sm text-muted-foreground"
        >
          没有找到相关结果
        </div>

        <!-- Results list -->
        <ul
          id="search-results"
          role="listbox"
          aria-label="搜索结果"
          class="hidden p-2 space-y-0.5"
        ></ul>
      </div>

      <!-- Footer -->
      <div
        class="flex items-center gap-4 border-t border-border px-3 py-2 text-xs text-muted-foreground select-none"
      >
        <div class="flex items-center gap-1">
          <kbd class="rounded border border-border px-1 py-0.5">↑</kbd>
          <kbd class="rounded border border-border px-1 py-0.5">↓</kbd>
          <span>导航</span>
        </div>
        <div class="flex items-center gap-1">
          <kbd class="rounded border border-border px-1 py-0.5">↵</kbd>
          <span>打开</span>
        </div>
        <div class="flex items-center gap-1">
          <kbd class="rounded border border-border px-1 py-0.5">Esc</kbd>
          <span>关闭</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Load pagefind only in production builds -->
{
  import.meta.env.PROD && (
    <script
      is:inline
      define:vars={{ _pagefindUrl: '/pagefind/pagefind.js' }}
    >
      ;(async () => {
        if (window.pagefind) return
        try {
          const pf = await import(_pagefindUrl)
          await pf.options({ excerptLength: 30 })
          pf.init()
          window.pagefind = pf
          window.dispatchEvent(new CustomEvent('pagefind:ready'))
        } catch (e) {
          console.error('[Search] Failed to load pagefind:', e)
        }
      })()
    </script>
  )
}

<script>
  const toggle = document.getElementById('search-toggle')!
  const overlay = document.getElementById('search-overlay')!
  const backdrop = document.getElementById('search-backdrop')!
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  const resultsEl = document.getElementById('search-results')!
  const emptyEl = document.getElementById('search-empty')!
  const noResultsEl = document.getElementById('search-no-results')!

  let selectedIndex = -1

  // ── Open / Close ────────────────────────────────────────────────────────────

  function openDialog() {
    overlay.classList.remove('hidden')
    document.body.style.overflow = 'hidden'
    // requestAnimationFrame ensures the element is visible before focusing
    requestAnimationFrame(() => searchInput.focus())
  }

  function closeDialog() {
    overlay.classList.add('hidden')
    document.body.style.overflow = ''
    searchInput.value = ''
    resetResults()
  }

  function resetResults() {
    emptyEl.classList.remove('hidden')
    noResultsEl.classList.add('hidden')
    resultsEl.classList.add('hidden')
    resultsEl.innerHTML = ''
    selectedIndex = -1
  }

  // ── Triggers ─────────────────────────────────────────────────────────────────

  toggle.addEventListener('click', openDialog)
  backdrop.addEventListener('click', closeDialog)

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      openDialog()
    }
  })

  // ── Keyboard navigation inside the dialog ───────────────────────────────────

  searchInput.addEventListener('keydown', (e) => {
    const items = resultsEl.querySelectorAll<HTMLElement>('li[role="option"]')

    if (e.key === 'Escape') {
      closeDialog()
    } else if (e.key === 'ArrowDown') {
      e.preventDefault()
      selectedIndex = Math.min(selectedIndex + 1, items.length - 1)
      updateHighlight(items)
    } else if (e.key === 'ArrowUp') {
      e.preventDefault()
      selectedIndex = Math.max(selectedIndex - 1, 0)
      updateHighlight(items)
    } else if (e.key === 'Enter') {
      e.preventDefault()
      const idx = selectedIndex >= 0 ? selectedIndex : 0
      const link = items[idx]?.querySelector<HTMLAnchorElement>('a')
      if (link) {
        window.location.href = link.href
        closeDialog()
      }
    }
  })

  function updateHighlight(items: NodeListOf<HTMLElement>) {
    items.forEach((item, i) => {
      const active = i === selectedIndex
      item.setAttribute('aria-selected', String(active))
      item.classList.toggle('bg-muted', active)
      if (active) item.scrollIntoView({ block: 'nearest' })
    })
  }

  // ── Search ───────────────────────────────────────────────────────────────────

  searchInput.addEventListener('input', async () => {
    const query = searchInput.value.trim()
    if (!query) {
      resetResults()
      return
    }

    // Dev mode: pagefind is not available
    if (!(window as any).pagefind) {
      resultsEl.innerHTML = `<li class="px-3 py-6 text-center text-sm text-muted-foreground">搜索功能仅在构建版本中可用<br><code class="text-xs opacity-60">pnpm build &amp;&amp; pnpm preview</code></li>`
      resultsEl.classList.remove('hidden')
      emptyEl.classList.add('hidden')
      noResultsEl.classList.add('hidden')
      return
    }

    try {
      const result = await (window as any).pagefind.debouncedSearch(query)
      if (!result) return // superseded by a newer search

      const topResults = result.results.slice(0, 8)
      const data: any[] = await Promise.all(topResults.map((r: any) => r.data()))
      renderResults(data)
    } catch (err) {
      console.error('[Search] Error:', err)
    }
  })

  function escHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  function renderResults(data: any[]) {
    selectedIndex = -1
    emptyEl.classList.add('hidden')

    if (!data.length) {
      resultsEl.innerHTML = ''
      resultsEl.classList.add('hidden')
      noResultsEl.classList.remove('hidden')
      return
    }

    noResultsEl.classList.add('hidden')
    resultsEl.classList.remove('hidden')

    resultsEl.innerHTML = data
      .map((item) => {
        const title = escHtml(item.meta?.title || item.url)
        const url = item.url
        const excerpt: string = item.excerpt || ''
        return `
        <li role="option" aria-selected="false" class="rounded-md list-none">
          <a
            href="${url}"
            class="flex flex-col gap-0.5 rounded-md px-3 py-2 hover:bg-muted transition-colors block"
          >
            <span class="text-sm font-medium text-foreground line-clamp-1">${title}</span>
            ${excerpt ? `<span class="text-xs text-muted-foreground line-clamp-2 [&_mark]:bg-primary/20 [&_mark]:text-foreground [&_mark]:rounded-sm [&_mark]:px-0.5">${excerpt}</span>` : ''}
          </a>
        </li>`
      })
      .join('')

    resultsEl.querySelectorAll<HTMLAnchorElement>('a').forEach((a) => {
      a.addEventListener('click', closeDialog)
    })
  }
</script>
